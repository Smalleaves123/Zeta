@PACKAGE_INIT@

set_and_check(ZETA_INCLUDE_DIR "@PACKAGE_ZETA_INCLUDE_DIR@")

if(NOT TARGET zeta)
    add_library(zeta INTERFACE IMPORTED)
    set_target_properties(zeta PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${ZETA_INCLUDE_DIR}"
        INTERFACE_COMPILE_FEATURES "cxx_std_20")
endif()

check_required_components(zeta)
